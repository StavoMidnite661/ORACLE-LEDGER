{
  "name": "sovrcvlt-oracle-ledger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx server/api.ts",
    "dev:bank": "cross-env BANK_CONNECTOR_PORT=3007 tsx microservices/bank-connector/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "dev:all": "concurrently -n \"FRONT,BACK,GATE,RISK,CHAIN,PAY,BANK\" -c \"bgBlue.bold,bgMagenta.bold,bgGreen.bold,bgRed.bold,bgCyan.bold,bgYellow.bold,bgWhite.bold\" \"npm run dev\" \"npm run dev:backend\" \"tsx microservices/gateway/index.ts\" \"tsx microservices/risk-compliance/index.ts\" \"tsx microservices/blockchain-bridge/index.ts\" \"tsx microservices/payment-gateway/index.ts\" \"cross-env BANK_CONNECTOR_PORT=3007 tsx microservices/bank-connector/index.ts\"",
    "build": "vite build",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "tsx services/blockchainService.test.ts",
    "test:bank-direct": "tsx scripts/execute-bank-transfer.ts",
    "compile-contracts": "hardhat compile",
    "start-node": "hardhat node"
  },
  "dependencies": {
    "@google/genai": "^1.16.0",
