    "@types/express": "^5.0.3",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.5",
    "body-parser": "^2.2.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "ethers": "^6.15.0",
    "express": "^5.1.0",
    "express-status-monitor": "^1.3.4",
    "iso20022.js": "^0.2.5",
    "lucide-react": "^0.563.0",
    "pg": "^8.17.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.1.2",
    "stripe": "^16.8.0",
